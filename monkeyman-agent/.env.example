# ───────────────────────────────────────────────────────────────
# MonkeyMan Agent — environment variables
# Copy this file to `.env` for local dev, or paste these into
# Vercel → Project Settings → Environment Variables for production.
# ───────────────────────────────────────────────────────────────

# LLM provider — Google Gemini (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# MonkeyMan API base — existing backend
MONKEYMAN_API_BASE=https://server.monkeymans.com/api

# Shared login password for the chat console.
# Leave blank to accept any password (demo mode only — do NOT do this in production).
LOGIN_PASSWORD=change-me

# Server port (Vercel ignores this — it injects its own PORT)
PORT=3000

# Optional: cap tool-use loops per user message (default 15)
MAX_TOOL_ROUNDS=15
